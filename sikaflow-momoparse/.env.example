# --- Obligatoire en production (Vercel, etc.) ---
# Clés API acceptées par /api/v1/* (séparées par des virgules).
# En local, si vide : clé de dev mklive_dev_sikaflow_local (voir lib/api/auth.ts).
SIKAFLOW_API_KEYS=mklive_dev_sikaflow_local

# Optionnel : restreindre CORS (sinon *). Ex. https://votredomaine.com
# SIKAFLOW_CORS_ORIGIN=https://app.example.com

# --- Supabase (optionnel en local) ---
# Sans NEXT_PUBLIC_* : middleware désactivé, dashboard accessible sans login (démo).
# Avec NEXT_PUBLIC_* : login / inscription Supabase obligatoires pour /dashboard.
# SERVICE_ROLE : persistance API (/api/v1) si vous utilisez la table SQL (voir supabase/migrations).
# https://supabase.com → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# (optionnel, même URL que ci-dessus si vous préférez une var serveur seule)
# SUPABASE_URL=https://xxxx.supabase.co

# Optionnel : préremplir le champ clé sur la page Documentation (dashboard).
# Ne mettez JAMAIS une clé secrète de production ici si le repo est public.
# SIKAFLOW_DOCS_DEMO_KEY=mklive_dev_sikaflow_local
